{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/create-organization", "destination": "/create-organization.html" },
    { "source": "/app", "destination": "/dashboard.html" },
    { "source": "/app/u", "destination": "/users.html" },
    { "source": "/verify", "destination": "/verify.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" }
  ],
  "redirects": [
    { "source": "/login.html", "destination": "/login", "permanent": true },
    { "source": "/org.html", "destination": "/", "permanent": true },
    { "source": "/dashboard.html", "destination": "/app", "permanent": true },
    { "source": "/dashboard", "destination": "/app", "permanent": true },
    { "source": "/create-organization.html", "destination": "/create-organization", "permanent": true },
    { "source": "/users.html", "destination": "/app/u", "permanent": true },
    { "source": "/users", "destination": "/app/u", "permanent": true },
    { "source": "/verify.html", "destination": "/verify", "permanent": false },
    { "source": "/forgot-password.html", "destination": "/forgot-password", "permanent": true },
    { "source": "/reset-password.html", "destination": "/reset-password", "permanent": false }
  ]
}
