# Postgres connection string (Supabase or other Postgres)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# SMTP (Zoho) settings
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=you@yourdomain.com
ZOHO_SMTP_PASS=app-password-from-zoho
ZOHO_FROM_EMAIL=you@yourdomain.com

# App settings
SITE_URL=http://localhost:5500
PORT=3000

# JWT secret for signing tokens (keep secret)
JWT_SECRET=replace_with_a_strong_secret
